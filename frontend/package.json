{
  "name": "frontend",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:perf": "echo 'Run lighthouse or other performance tools' && exit 0",
    "prepare": "husky"
  },
  "dependencies": {
    "@nuxtjs/i18n": "10.3.0",
    "@pinia/nuxt": "0.11.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^1.0.0",
    "nuxt": "^4.4.2",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.6",
    "shadcn-nuxt": "2.6.2",
    "shadcn-vue": "^2.6.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^4.0.3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@vitejs/plugin-vue": "^6.0.6",
    "happy-dom": "^20.9.0",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.2.4",
    "vitest": "^4.1.5"
  }
